# =============================================================================
# Taylor Made Law — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For LOCAL MOCK MODE (no Base44 credentials needed):
#   Set VITE_USE_MOCKS=true and leave the Base44 vars empty.
#   Run: npm run dev:local
#
# For LIVE MODE (connects to real Base44 backend):
#   Fill in all VITE_BASE44_* vars with values from the Base44 dashboard.
#   Run: npm run dev
# =============================================================================

# --- Mock Mode Toggle ---
# Set to "true" to run with mock data (no Base44 backend needed)
# Set to "false" or remove to connect to real Base44 backend
VITE_USE_MOCKS=true

# --- Frontend (Vite / React) ---
# Base44 Application ID (from Base44 dashboard → App Settings)
VITE_BASE44_APP_ID=

# Base44 Functions Version (from Base44 dashboard → Deployments)
VITE_BASE44_FUNCTIONS_VERSION=

# Base44 App Base URL (the deployed Base44 app URL)
VITE_BASE44_APP_BASE_URL=

# --- Supabase (local or hosted) ---
# Local defaults shown. Override for hosted Supabase project.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-start>

# --- Provider Feature Flags ---
# Controls which backend serves each domain. Values: 'base44' (default) or 'supabase'.
# Set individually to migrate one domain at a time. Rollback by setting back to 'base44'.
VITE_PROVIDER_CONTENT_READ=base44
VITE_PROVIDER_PROFILE_READ=base44
VITE_PROVIDER_CASES_READ=base44
VITE_PROVIDER_CIRCLES_READ=base44
VITE_PROVIDER_MESSAGING_READ=base44
VITE_PROVIDER_AUTH=base44

# =============================================================================
# BACKEND-ONLY VARIABLES (Reference Only)
# These are set in the Base44 dashboard, NOT in this file.
# Listed here for documentation purposes.
# =============================================================================
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# RESEND_API_KEY=re_...
# APP_URL=https://app.taylormadelaw.com
# BASE44_APP_ID=<same as VITE_BASE44_APP_ID>
